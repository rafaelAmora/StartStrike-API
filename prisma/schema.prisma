generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  steam64Id  String    @unique
  leetifyId  String?
  avatarUrl  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSyncAt DateTime?

  playerMatchStats PlayerMatchStats[]
  userStatsCache   UserStatsCache?
}

model Match {
  id               String             @id @default(uuid())
  externalMatchId  String             @unique
  mapName          String
  finishedAt       DateTime
  team1Score       Int
  team2Score       Int
  createdAt        DateTime           @default(now())
  playerMatchStats PlayerMatchStats[]
}

model PlayerMatchStats {
  id String @id @default(uuid())

  userId  String
  matchId String

  kills              Int
  deaths             Int
  assists            Int
  totalDamage        Float
  mvps               Int
  kdRatio            Float
  leetifyRating      Float
  ctRating           Float
  tRating            Float
  headshotKills      Int
  headshotPercentage Float
  win                Boolean
  createdAt          DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [externalMatchId], onDelete: Cascade)

  @@unique([userId, matchId])
}

model UserStatsCache {
  id                 String   @id @default(uuid())
  userId             String   @unique
  totalMatches       Int
  avgKd              Float
  avgRating          Float
  winRate            Float
  headshotPercentage Float
  utility            Float
  aim                Float
  positioning        Float
  clutch             Float
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
